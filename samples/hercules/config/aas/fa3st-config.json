{
  "core": {
    "aasRegistries": ["http://dtr:8090"]
  },
  "endpoints": [
    {
      "@class": "de.fraunhofer.iosb.ilt.faaast.service.endpoint.http.HttpEndpoint",
      "port": 12345,
      "hostname": "http://data-plane:9500/public",
