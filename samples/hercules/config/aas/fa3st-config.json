      "subprotocolBodyEncoding": "plain",
      "sniEnabled": false,
      "sslEnabled": false
    }
  ],
  "persistence": {
    "@class": "de.fraunhofer.iosb.ilt.faaast.service.persistence.memory.PersistenceInMemory",
    "initialModelFile": "/resources/fa3st/model.aasx"
  }
}
