<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout
    disableAnsi="false"
    pattern="%d{HH:mm:ss} %highlight{%-5level}{FATAL=bright red, ERROR=red, WARN=yellow, INFO=green, DEBUG=cyan, TRACE=blue} %style{%logger{60}}{blue} - %msg%n%throwable"/>
        </Console>
    </Appenders>

    <Loggers>
        <Logger name="org.eclipse.edc" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <Logger name="org.eclipse.tractusx" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <Logger name="io.micrometer" level="info" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <Logger name="org.glassfish.jersey" level="info" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>